# Copy to .env to override the default MaisonLooks spreadsheet hub URL
# Default if unset: https://maisonlooks.com/en/spreadsheet
PUBLIC_OOPBUY_SPREADSHEET_URL=

# TOP promo strip → `/join/discord` redirect (optional; default in src/consts.ts).
# PUBLIC_OOPBUY_DISCORD_URL=https://discord.gg/9hrqg53zgs

# Floating right dock (Video / Discord / Reddit / WhatsApp). Optional overrides — see defaults in src/consts.ts (CDN intro MP4).
# PUBLIC_FLOAT_VIDEO_URL=https://example.com/my-intro.mp4
# PUBLIC_FLOAT_DISCORD_URL=https://discord.gg/9hrqg53zgs
# PUBLIC_FLOAT_REDDIT_URL=https://www.reddit.com/r/...
# PUBLIC_FLOAT_WHATSAPP_URL=https://wa.me/447594927259
