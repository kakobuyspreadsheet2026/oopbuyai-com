---
/**
 * Intermediate page so the promo strip can link to Same-Origin (/join/discord).
 * Many blockers hide elements whose href points at discord.* — this avoids that pattern.
 */
import { defaultOopbuyDiscordUrl } from '../../consts';

export const prerender = true;

const target =
  typeof import.meta.env.PUBLIC_OOPBUY_DISCORD_URL === 'string'
    ? import.meta.env.PUBLIC_OOPBUY_DISCORD_URL.trim()
    : '';
const discordUrl = target || defaultOopbuyDiscordUrl;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Join the Oopbuy Spreadsheet community hub on Discord—share Taobao / Weidian finds, QC checks, and paste-to-Oopbuy workflow tips. Redirects to the live Discord invite."
    />
    <meta
      name="keywords"
      content="Oopbuy Spreadsheet Discord, Oopbuy community server, shopping agent spreadsheet Discord, Weidian Oopbuy chat"
    />
    <meta http-equiv="refresh" content={`0;url=${discordUrl}`} />
    <title>Redirecting…</title>
    <link rel="canonical" href={new URL('/join/discord', Astro.site).href} />
  </head>
  <body
    style="margin:0;font-family:system-ui,sans-serif;padding:2rem;background:#f6f6fb;color:#1a1a1a;line-height:1.5"
  >
    <p style="margin:0 0 0.75rem">Redirecting to Discord…</p>
    <p style="margin:0">
      If nothing happens, <a href={discordUrl} style="color:#e91362">open the invite manually</a>.
    </p>
  </body>
</html>
