---
import Layout from '../../../layouts/Layout.astro';
import SpreadsheetPageBody from '../../../components/pages/SpreadsheetPageBody.astro';
import { ml, siteStructuredDataIds } from '../../../consts';
import {
  getSpreadsheetPageCopy,
  hydrateSpreadsheetCopy,
} from '../../../i18n/copy/spreadsheetPage';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { HTML_LANG_BY_ROUTE } from '../../../i18n/config';

export const prerender = true;

const locale = 'pl';
const canonicalPath = '/pl/spreadsheet';
const sheetUrl =
  import.meta.env.PUBLIC_OOPBUY_SPREADSHEET_URL?.trim() || `${ml}/spreadsheet`;

const howToHref = getRelativeLocaleUrl(locale, 'how-to-buy');
const newsHref = getRelativeLocaleUrl(locale, 'news');
const raw = getSpreadsheetPageCopy(locale);
const copy = hydrateSpreadsheetCopy(raw, ml, howToHref, newsHref);
const homeHref = getRelativeLocaleUrl(locale, '');

const origin = Astro.site?.origin ?? 'https://oopbuyai.com';
const { websiteId } = siteStructuredDataIds(origin);
const pageUrl = new URL(canonicalPath, Astro.site).href;

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${pageUrl}#webpage`,
  name: copy.title,
  url: pageUrl,
  description: copy.description,
  inLanguage: HTML_LANG_BY_ROUTE[locale],
  isPartOf: { '@id': websiteId },
  keywords: copy.keywords,
};
---

<Layout
  title={copy.title}
  description={copy.description}
  keywords={copy.keywords}
  canonicalPath={canonicalPath}
  locale={locale}
  i18nRouteSegment="spreadsheet"
  jsonLd={webPageLd}
>
  <SpreadsheetPageBody
    locale={locale}
    copy={copy}
    homeHref={homeHref}
    howToHref={howToHref}
    newsHref={newsHref}
    sheetUrl={sheetUrl}
  />
</Layout>
