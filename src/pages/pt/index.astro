---
import Layout from '../../layouts/Layout.astro';
import LocaleHomeStub from '../../components/LocaleHomeStub.astro';
import { ptHome } from '../../i18n/stubs/pt';
import { ml, siteStructuredDataIds } from '../../consts';

export const prerender = true;

const locale = 'pt';
const canonicalPath = '/pt/';
const origin = Astro.site?.origin ?? 'https://oopbuyai.com';
const { websiteId } = siteStructuredDataIds(origin);
const pageUrl = new URL(canonicalPath, Astro.site).href;

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${pageUrl}#webpage`,
  name: ptHome.webPageName,
  url: pageUrl,
  description: ptHome.description,
  inLanguage: 'pt',
  isPartOf: { '@id': websiteId },
  keywords: ptHome.webPageKeywords,
};
---

<Layout
  locale={locale}
  title={ptHome.title}
  description={ptHome.description}
  keywords={ptHome.keywords}
  canonicalPath={canonicalPath}
  i18nRouteSegment=""
  jsonLd={webPageLd}
>
  <LocaleHomeStub content={ptHome} />
</Layout>
