---
import {
  defaultFloatingIntroVideoUrl,
  defaultFloatingWhatsappUrl,
  defaultOopbuyDiscordUrl,
} from '../consts';

/**
 * Floating dock: inline intro video panel + outbound links.
 * Default: Oopbuy CDN MP4 (`defaultFloatingIntroVideoUrl` in consts.ts).
 * Override with `PUBLIC_FLOAT_VIDEO_URL` (HTTPS URL or same-origin path).
 */
const introVideoSrc =
  import.meta.env.PUBLIC_FLOAT_VIDEO_URL?.trim() || defaultFloatingIntroVideoUrl;
const discordUrl =
  import.meta.env.PUBLIC_FLOAT_DISCORD_URL?.trim() || defaultOopbuyDiscordUrl;
const redditUrl =
  import.meta.env.PUBLIC_FLOAT_REDDIT_URL?.trim() || 'https://www.reddit.com/r/FashionReps/';
const whatsappUrl =
  import.meta.env.PUBLIC_FLOAT_WHATSAPP_URL?.trim() || defaultFloatingWhatsappUrl;

type LinkItem = { id: string; label: string; href: string | null };

const linkItems: LinkItem[] = [
  { id: 'discord', label: 'Discord', href: discordUrl },
  { id: 'reddit', label: 'Reddit', href: redditUrl },
  { id: 'whatsapp', label: 'WhatsApp', href: whatsappUrl },
];

const videoIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="15" height="16" rx="2"/><path d="m15 8 5-2v12l-5-2"/></svg>`;
const discordIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.927 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>`;
const whatsappIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.883 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`;

const redditDockIcon = '/icons/reddit-snoo.png';
---

<div class="floating-dock-root" data-floating-dock-root>
  <div
    id="floating-dock-backdrop"
    class="floating-dock-backdrop"
    aria-hidden="true"
  ></div>
  <div class="floating-dock-tray">
    <button
      type="button"
      class="floating-dock-expand-tab"
      id="floating-dock-expand-tab"
      tabindex="0"
      hidden
      aria-controls="floating-dock-shell"
      aria-label="Show floating quick links bar"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m15 18-6-6 6-6"></path>
      </svg>
    </button>
    <div class="floating-dock-shell" id="floating-dock-shell">
    <div
      id="floating-dock-video-panel"
      class="floating-dock-video-panel"
      role="dialog"
      aria-modal="true"
      aria-label="Introduction video"
      hidden
    >
      <button
        type="button"
        class="floating-dock-video-panel__close"
        id="floating-dock-video-close"
        aria-label="Close video"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"></path>
        </svg>
      </button>
      <video
        id="floating-dock-video-el"
        class="floating-dock-video-panel__video"
        controls
        playsinline
        preload="metadata"
        aria-label="Oopbuy and Oopbuy Spreadsheet hub introduction video"
      >
        <source src={introVideoSrc} type="video/mp4" />
      </video>
    </div>
    <nav class="floating-dock" aria-label="Quick links">
      <div class="floating-dock__inner">
        <button
          type="button"
          class="floating-dock-mobile-hide"
          id="floating-dock-collapse"
          aria-controls="floating-dock-shell"
          aria-expanded="true"
          aria-label="Hide quick links bar"
        >
          <span class="floating-dock-mobile-hide__icon" aria-hidden="true">⟨</span>
          <span class="floating-dock-mobile-hide__text">Hide</span>
        </button>
        <button
          type="button"
          class="floating-dock__btn floating-dock__btn--video"
          id="floating-dock-video-toggle"
          aria-label="Play introduction video"
          aria-expanded="false"
          aria-controls="floating-dock-video-panel"
        >
          <span class="floating-dock__icon" set:html={videoIcon} />
        </button>
        {
          linkItems.map((item) => {
            const iconSvg = item.id === 'discord' ? discordIcon : whatsappIcon;
            const commonClass = `floating-dock__btn floating-dock__btn--${item.id}`;
            const iconInner =
              item.id === 'reddit' ? (
                <span class="floating-dock__icon floating-dock__icon--reddit">
                  <img
                    src={redditDockIcon}
                    alt="Reddit Snoo icon — r/FashionReps and Oopbuy Spreadsheet community link"
                    width="22"
                    height="22"
                    loading="lazy"
                    decoding="async"
                    draggable="false"
                  />
                </span>
              ) : (
                <span class="floating-dock__icon" set:html={iconSvg} />
              );
            if (item.href) {
              return (
                <a
                  class={commonClass}
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={item.label}
                  title={item.label}
                >
                  {iconInner}
                </a>
              );
            }
            return (
              <span
                class:list={[commonClass, 'floating-dock__btn--inactive']}
                aria-label="WhatsApp: not linked yet"
                title="Add PUBLIC_FLOAT_WHATSAPP_URL in .env"
              >
                {iconInner}
              </span>
            );
          })
        }
        <button type="button" class="floating-dock__btn floating-dock__btn--top" id="floating-dock-scroll-top" aria-label="Back to top" title="Back to top">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m18 15-6-6-6 6"></path>
          </svg>
        </button>
      </div>
    </nav>
  </div>
  </div>
</div>

<script is:inline>
  (function () {
    const FLOAT_DOCK_COLLAPSED_KEY = 'oob-floating-dock-collapsed-mobile';
    const MOBILE_MQ = '(max-width: 640px)';

    const root = document.querySelector('[data-floating-dock-root]');
    const shell = document.getElementById('floating-dock-shell');
    const expandTab = document.getElementById('floating-dock-expand-tab');
    const collapseBtn = document.getElementById('floating-dock-collapse');
    const backdrop = document.getElementById('floating-dock-backdrop');
    const panel = document.getElementById('floating-dock-video-panel');
    const toggle = document.getElementById('floating-dock-video-toggle');
    const closeBtn = document.getElementById('floating-dock-video-close');
    const video = document.getElementById('floating-dock-video-el');

    const mq = typeof window.matchMedia === 'function' ? window.matchMedia(MOBILE_MQ) : null;

    /** @returns {boolean} */
    function isMobileDock() {
      return mq ? mq.matches : window.innerWidth <= 640;
    }

    function openPanel() {
      if (!backdrop || !panel || !toggle) return;
      backdrop.classList.add('floating-dock-backdrop--visible');
      backdrop.setAttribute('aria-hidden', 'false');
      panel.removeAttribute('hidden');
      panel.classList.add('floating-dock-video-panel--open');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.classList.add('floating-dock__btn--video-active');
      document.documentElement.style.overflow = 'hidden';
      closeBtn?.focus();
    }

    function closePanel() {
      if (!backdrop || !panel || !toggle) return;
      backdrop.classList.remove('floating-dock-backdrop--visible');
      backdrop.setAttribute('aria-hidden', 'true');
      panel.classList.remove('floating-dock-video-panel--open');
      panel.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.classList.remove('floating-dock__btn--video-active');
      document.documentElement.style.overflow = '';
      try {
        /** @type {HTMLMediaElement|null} */
        const v = video;
        if (v) v.pause();
      } catch {
        //
      }
    }

    /** @param {boolean} collapsed */
    function syncDockCollapsed(collapsed) {
      if (!root) return;
      const mobile = isMobileDock();
      if (!mobile) {
        root.classList.remove('floating-dock-root--dock-collapsed');
        if (shell) shell.removeAttribute('aria-hidden');
        if (collapseBtn) collapseBtn.setAttribute('aria-expanded', 'true');
        if (expandTab) expandTab.hidden = true;
        return;
      }
      if (collapsed) closePanel();

      root.classList.toggle('floating-dock-root--dock-collapsed', collapsed);
      if (shell) shell.setAttribute('aria-hidden', collapsed ? 'true' : 'false');
      if (collapseBtn) collapseBtn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
      if (expandTab) expandTab.hidden = !collapsed;

      if (!collapsed && document.activeElement === expandTab) {
        collapseBtn?.focus();
      }
    }

    /** @returns {'hide'|'show'|null} */
    function readDockPreference() {
      try {
        const v = localStorage.getItem(FLOAT_DOCK_COLLAPSED_KEY);
        if (v === '1') return 'hide';
        if (v === '0') return 'show';
        return null;
      } catch {
        return null;
      }
    }

    function persistDockPreference(collapsed) {
      try {
        localStorage.setItem(FLOAT_DOCK_COLLAPSED_KEY, collapsed ? '1' : '0');
      } catch {
        //
      }
    }

    function applyStoredOrDefault() {
      const mobile = isMobileDock();
      if (!mobile) {
        syncDockCollapsed(false);
        return;
      }
      const pref = readDockPreference();
      const collapsed = pref === null ? true : pref === 'hide';
      syncDockCollapsed(collapsed);
    }

    mq?.addEventListener('change', applyStoredOrDefault);
    window.addEventListener('orientationchange', () => window.setTimeout(applyStoredOrDefault, 120));

    expandTab?.addEventListener('click', () => {
      syncDockCollapsed(false);
      persistDockPreference(false);
    });
    collapseBtn?.addEventListener('click', () => {
      syncDockCollapsed(true);
      persistDockPreference(true);
    });

    applyStoredOrDefault();

    toggle?.addEventListener('click', () => {
      const open = panel && !panel.hasAttribute('hidden') && panel.classList.contains('floating-dock-video-panel--open');
      if (open) closePanel();
      else openPanel();
    });
    closeBtn?.addEventListener('click', () => closePanel());
    backdrop?.addEventListener('click', () => closePanel());

    document.getElementById('floating-dock-scroll-top')?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && backdrop?.classList.contains('floating-dock-backdrop--visible')) {
        closePanel();
        toggle?.focus();
      }
    });
  })();
</script>

<style>
  .floating-dock-root {
    position: fixed;
    inset: 0;
    z-index: 90;
    pointer-events: none;
    direction: ltr;
  }
  .floating-dock-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.38);
    z-index: 0;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.22s ease,
      visibility 0.22s ease;
    pointer-events: none;
  }
  .floating-dock-backdrop--visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .floating-dock-tray {
    position: absolute;
    z-index: 1;
    right: max(0.65rem, env(safe-area-inset-right, 0px));
    top: 50%;
    transform: translateY(-50%);
    pointer-events: auto;
  }
  .floating-dock-shell {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 0.5rem;
    position: relative;
  }
  .floating-dock-video-panel {
    order: -1;
    position: absolute;
    right: calc(100% + 0.45rem);
    top: 0;
    display: none;
    flex-direction: column;
    width: min(52vw, 384px);
    max-height: min(72vh, 520px);
    background: #0f0f12;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.65rem;
    overflow: hidden;
    box-shadow:
      0 28px 64px rgba(0, 0, 0, 0.45),
      0 12px 24px rgba(0, 0, 0, 0.25);
  }
  .floating-dock-video-panel--open {
    display: flex;
  }
  .floating-dock-video-panel__close {
    position: absolute;
    top: 0.4rem;
    right: 0.4rem;
    z-index: 2;
    width: 2rem;
    height: 2rem;
    border: none;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    transition: background 0.15s ease;
  }
  .floating-dock-video-panel__close:hover {
    background: rgba(0, 0, 0, 0.72);
  }
  .floating-dock-video-panel__video {
    display: block;
    width: 100%;
    max-height: min(72vh, 520px);
    background: #000;
  }
  .floating-dock-root:has(.floating-dock-video-panel--open) {
    z-index: 130;
  }
  .floating-dock {
    position: relative;
    z-index: 2;
  }
  .floating-dock__inner {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.35rem;
    padding: 0.45rem;
    background: var(--surface, #fff);
    border: 1px solid var(--border, #e8e8f0);
    border-radius: 0.75rem;
    box-shadow:
      0 10px 30px rgba(15, 23, 42, 0.12),
      0 2px 8px rgba(15, 23, 42, 0.06);
  }
  .floating-dock__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.65rem;
    height: 2.65rem;
    border: none;
    border-radius: 0.5rem;
    background: #f4f4f7;
    color: #1a1a1a;
    cursor: pointer;
    text-decoration: none;
    transition:
      background 0.15s ease,
      color 0.15s ease,
      box-shadow 0.15s ease;
  }
  .floating-dock__btn:hover {
    background: var(--accent-soft, rgba(255, 30, 111, 0.08));
    color: var(--accent-dark, #e91362);
  }
  .floating-dock__btn--video {
    color: var(--accent-dark, #e91362);
  }
  .floating-dock__btn--video-active {
    background: rgba(233, 19, 98, 0.12);
    box-shadow:
      inset 0 0 0 2px var(--accent, #ff1e6f),
      0 0 0 1px rgba(255, 30, 111, 0.15);
  }
  .floating-dock__btn--discord {
    color: #5865f2;
  }
  .floating-dock__btn--discord:hover {
    color: #4752c4;
  }
  /* Reddit: PNG Snoo artwork (orange baked in); no currentColor tint */
  .floating-dock__icon--reddit img {
    width: 22px;
    height: 22px;
    display: block;
    border-radius: 0.38rem;
    object-fit: cover;
  }
  .floating-dock__btn--reddit:hover .floating-dock__icon--reddit img {
    filter: brightness(1.05);
  }
  .floating-dock__btn--whatsapp {
    color: #25d366;
  }
  .floating-dock__btn--whatsapp:hover {
    color: #1da851;
  }
  .floating-dock__btn--inactive {
    opacity: 0.38;
    cursor: not-allowed;
    pointer-events: none;
  }
  .floating-dock__btn--top {
    margin-top: 0.2rem;
    padding-top: 0.35rem;
    border-top: 1px solid var(--border, #e8e8f0);
    border-radius: 0.35rem;
    background: transparent;
    color: var(--muted, #666);
  }
  .floating-dock__btn--top:hover {
    background: #f4f4f7;
    color: var(--accent-dark, #e91362);
  }
  .floating-dock__icon {
    display: flex;
    line-height: 0;
  }
  .floating-dock__icon :global(svg) {
    display: block;
  }

  .floating-dock-expand-tab {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    border: 1px solid var(--border, #e8e8f0);
    background: var(--surface, #fff);
    color: var(--text, #1a1a1a);
    box-shadow:
      0 8px 22px rgba(15, 23, 42, 0.14),
      0 2px 6px rgba(15, 23, 42, 0.06);
    cursor: pointer;
    pointer-events: auto;
    transition:
      color 0.15s ease,
      box-shadow 0.18s ease,
      transform 0.18s ease;
  }

  .floating-dock-expand-tab:hover {
    color: var(--accent-dark, #e91362);
    box-shadow:
      0 10px 28px rgba(15, 23, 42, 0.16),
      0 3px 8px rgba(15, 23, 42, 0.08);
  }

  .floating-dock-expand-tab:active {
    transform: scale(0.96);
  }

  .floating-dock-mobile-hide {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    width: 100%;
    padding: 0.28rem 0.4rem;
    margin: 0 0 0.2rem;
    border: none;
    border-radius: 0.45rem;
    background: rgba(15, 23, 42, 0.06);
    color: var(--muted, #5c5c6b);
    font-size: 0.72rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    line-height: 1.2;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }

  .floating-dock-mobile-hide:hover {
    background: rgba(255, 30, 111, 0.08);
    color: var(--accent-dark, #e91362);
  }

  .floating-dock-mobile-hide__icon {
    font-size: 0.95rem;
    font-weight: 700;
    opacity: 0.85;
  }

  @media (max-width: 640px) {
    .floating-dock-mobile-hide {
      display: flex;
    }

    .floating-dock-root--dock-collapsed .floating-dock-shell {
      display: none;
    }

    .floating-dock-tray {
      top: auto;
      bottom: max(1rem, env(safe-area-inset-bottom, 0px));
      transform: none;
    }
    .floating-dock-video-panel {
      position: fixed;
      left: 50%;
      right: auto;
      top: 50%;
      transform: translate(-50%, -50%);
      width: min(94vw, 400px);
      max-height: min(78vh, 560px);
    }
  }
  @media print {
    .floating-dock-root {
      display: none;
    }
  }
</style>
