---
import HeaderNavBlock from './HeaderNavBlock.astro';

interface Props {
  /** true：顶栏铺在首页 hero 内，与主文案同一列对齐（无底部分割条） */
  embedded?: boolean;
  locale?: string;
}

const { embedded = false, locale } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class:list={['oob-site-header', embedded && 'oob-site-header--embedded']}>
  {
    embedded ? (
      <div class="oob-header-stack">
        <HeaderNavBlock pathname={pathname} locale={locale} />
      </div>
    ) : (
      <div class="wrap">
        <div class="page-mast">
          <div class="oob-header-stack">
            <HeaderNavBlock pathname={pathname} locale={locale} />
          </div>
        </div>
      </div>
    )
  }
</header>

<style is:global>
  .oob-site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    /* 与 .hero h1 / 正文一致，便于与「Oopbuy Spreadsheet…」主列对齐 */
    font-family: Inter, system-ui, sans-serif;
  }

  .oob-site-header--embedded {
    border-bottom: none;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    margin: 0 0 0.65rem;
  }

  .oob-site-header--embedded .oob-header-stack {
    padding-top: 0.15rem;
    padding-bottom: 0.42rem;
  }

  .oob-header-stack {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0.42rem 0 0.5rem;
  }

  /*
   * Hero h1 /.wrap 主列左缘：第一项导航药丸不占额外左 padding。
   */
  .oob-header-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    gap: 0.08rem;
    row-gap: 0.35rem;
    padding: 0;
    margin: 0;
    border: none;
  }

  .oob-nav-link {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.72rem;
    border-radius: 999px;
    font-size: 0.84375rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    border: none;
    background: transparent;
  }

  /* 与 .hero > .wrap 内 h1 主列左缘一致（首链左内边距勿再多缩一层） */
  .oob-nav-link.oob-nav-link--home {
    padding-left: 0;
  }

  .oob-nav-link:hover {
    color: var(--oob-pink, #ff1e6f);
  }
  .oob-nav-link--home,
  .oob-nav-link--accent {
    color: var(--oob-pink, #ff1e6f);
  }

  .oob-nav-dd {
    position: relative;
    flex-shrink: 0;
  }
  .oob-nav-dd-trigger {
    list-style: none;
    cursor: pointer;
    font-size: 0.84375rem;
    font-weight: 600;
    color: var(--text);
    padding: 0.38rem 1.52rem 0.38rem 0.72rem;
    border-radius: 999px;
    border: none;
    background: transparent;
    font-family: inherit;
    position: relative;
    user-select: none;
    white-space: nowrap;
  }
  .oob-nav-dd-trigger::-webkit-details-marker {
    display: none;
  }
  .oob-nav-dd-trigger::after {
    content: '';
    position: absolute;
    right: 0.6rem;
    top: 50%;
    width: 0.3rem;
    height: 0.3rem;
    border-right: 2px solid var(--muted);
    border-bottom: 2px solid var(--muted);
    transform: translateY(-62%) rotate(45deg);
    opacity: 0.92;
    pointer-events: none;
  }
  .oob-nav-dd[open] .oob-nav-dd-trigger::after {
    transform: translateY(-25%) rotate(-135deg);
  }
  .oob-nav-dd-trigger:hover {
    color: var(--oob-pink, #ff1e6f);
  }

  .oob-nav-dd-panel {
    position: absolute;
    left: 0;
    top: calc(100% + 0.42rem);
    min-width: 13rem;
    max-height: min(70vh, 21rem);
    overflow-y: auto;
    padding: 0.4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.55rem;
    box-shadow:
      0 12px 34px rgba(26, 27, 58, 0.12),
      0 2px 8px rgba(26, 27, 58, 0.05);
    z-index: 70;
  }

  .oob-nav-dd-link {
    display: block;
    padding: 0.42rem 0.58rem;
    border-radius: 0.35rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
  }
  .oob-nav-dd-link:hover {
    background: rgba(255, 30, 111, 0.06);
    color: var(--oob-pink, #ff1e6f);
  }

</style>
