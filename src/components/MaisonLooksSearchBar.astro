---
interface Props {
  /** Catalogue locale base URL for Oopbuy Spreadsheet search (no trailing slash). */
  mlBase: string;
  ariaLabel?: string;
  placeholder?: string;
  searchSubmitLabel?: string;
  searchByImageLabel?: string;
  searchByImageAria?: string;
  searchByImageTitle?: string;
}

const {
  mlBase,
  ariaLabel = 'Search Oopbuy Spreadsheet catalogue',
  placeholder = 'Search products, brands, styles...',
  searchSubmitLabel = 'Search',
  searchByImageLabel = 'Search by Image',
  searchByImageAria = 'Search by Image — opens MaisonLooks homepage in a new tab',
  searchByImageTitle = 'Search by Image — opens MaisonLooks in a new tab',
} = Astro.props;

const mlRoot = mlBase.replace(/\/$/, '');
const searchAction = `${mlRoot}/search`;
const searchByImageHref = mlRoot;

const camera = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>`;
---

<form
  class="ml-search-bar"
  action={searchAction}
  method="get"
  target="_blank"
  role="search"
  aria-label={ariaLabel}
>
  <div class="ml-search-bar__pill">
    <div class="ml-search-bar__main">
      <input
        type="search"
        name="q"
        class="ml-search-bar__input"
        placeholder={placeholder}
        autocomplete="off"
        enterkeyhint="search"
        maxlength="2048"
        required
      />
      <span class="ml-search-bar__divider" aria-hidden="true"></span>
      <a
        href={searchByImageHref}
        class="ml-search-bar__by-image"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={searchByImageAria}
        title={searchByImageTitle}
      >
        <span class="ml-search-bar__by-image-icon" set:html={camera} />
        <span class="ml-search-bar__by-image-text">{searchByImageLabel}</span>
      </a>
    </div>
    <button type="submit" class="ml-search-bar__submit">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.25"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      {searchSubmitLabel}
    </button>
  </div>
</form>

<script is:inline define:vars={{ searchAction }}>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('form.ml-search-bar').forEach((form) => {
      if (form.dataset.mlSearchNavigate) return;
      form.dataset.mlSearchNavigate = '1';
      form.addEventListener('submit', (e) => {
        const input = form.querySelector('input[name="q"]');
        const raw = input && 'value' in input ? String(input.value) : '';
        const q = raw.trim();
        if (!q) {
          e.preventDefault();
          if (input instanceof HTMLElement) input.focus();
          return;
        }
        e.preventDefault();
        const url = `${searchAction}?q=${encodeURIComponent(q)}`;
        const tab = window.open(url, '_blank', 'noopener,noreferrer');
        if (tab) tab.opener = null;
        else window.location.assign(url);
      });
    });
  });
</script>

<style>
  .ml-search-bar {
    width: 100%;
    max-width: min(42rem, 100%);
    margin: 0 0 1.35rem;
  }

  .ml-search-bar__pill {
    display: flex;
    align-items: stretch;
    width: 100%;
    border-radius: 999px;
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(232, 232, 240, 0.98);
    box-shadow:
      0 14px 44px rgba(26, 26, 26, 0.07),
      0 4px 12px rgba(26, 26, 26, 0.05);
    min-height: 3rem;
  }

  .ml-search-bar__main {
    flex: 1;
    display: flex;
    align-items: center;
    min-width: 0;
    gap: 0.35rem;
    padding: 0.35rem 0.05rem 0.35rem 1.05rem;
  }

  .ml-search-bar__input {
    flex: 1;
    min-width: 0;
    margin: 0;
    padding: 0.5rem 0.35rem 0.5rem 0;
    border: 0;
    background: transparent;
    font-family: inherit;
    font-size: 0.9375rem;
    color: var(--text);
    outline: none;
    -webkit-appearance: none;
    appearance: none;
  }

  .ml-search-bar__input::placeholder {
    color: var(--muted);
  }

  .ml-search-bar__divider {
    flex-shrink: 0;
    width: 1px;
    align-self: stretch;
    min-height: 1.35rem;
    margin: 0 0.15rem 0 0.25rem;
    background: var(--border);
    opacity: 0.85;
  }

  .ml-search-bar__by-image {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-right: 0.1rem;
    padding: 0.35rem 0.45rem 0.35rem 0.2rem;
    border-radius: 0.55rem;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: 600;
    white-space: nowrap;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }

  .ml-search-bar__by-image:hover {
    color: var(--oob-pink, #ff1e6f);
    background: rgba(255, 30, 111, 0.07);
  }

  .ml-search-bar__by-image-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ml-search-bar__by-image-icon :global(svg) {
    display: block;
  }

  .ml-search-bar__submit {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    margin: 0;
    padding: 0 1.15rem;
    border: none;
    border-radius: 0;
    background: var(--oob-pink, #ff1e6f);
    color: #fff;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition:
      filter 0.15s ease,
      background 0.15s ease;
  }

  .ml-search-bar__submit:hover {
    filter: brightness(1.06);
  }

  .ml-search-bar__submit :global(svg) {
    display: block;
    flex-shrink: 0;
  }

  @media (max-width: 520px) {
    .ml-search-bar__main {
      padding-left: 0.85rem;
    }

    .ml-search-bar__submit {
      padding: 0 0.95rem;
    }

    .ml-search-bar__pill {
      min-height: 2.875rem;
    }
  }

  @media (max-width: 380px) {
    .ml-search-bar__by-image-text {
      display: none;
    }

    .ml-search-bar__divider {
      margin-right: 0.05rem;
    }

    .ml-search-bar__submit {
      font-size: 0.8125rem;
      padding: 0 0.82rem;
    }
  }
</style>
